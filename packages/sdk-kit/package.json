{
  "name": "@oapiex/sdk-kit",
  "type": "module",
  "version": "0.1.14",
  "description": "A TypeScript Base for building SDKs using OpenAPI specifications extracted by OAPIEX.",
  "main": "./dist/index.js",
  "private": false,
  "homepage": "https://toneflix.github.io/oapiex/reference/sdk-kit",
  "repository": {
    "url": "https://github.com/toneflix/oapiex.git",
    "type": "git",
    "directory": "packages/sdk-kit"
  },
  "publishConfig": {
    "access": "public"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./contracts": "./dist/contracts.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "oapiex",
    "cli",
    "command-line",
    "tool",
    "integration",
    "sdk",
    "api",
    "developer",
    "oapiex-sdk",
    "toneflix"
  ],
  "scripts": {
    "test": "pnpm vitest --run",
    "test:watch": "pnpm vitest",
    "coverage": "pnpm vitest --coverage",
    "lint": "eslint . --ext .ts --ext .js",
    "build": "tsdown",
    "version:patch": "pnpm version patch",
    "barrel": "barrelize",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "dotenv": "^17.2.3",
    "jiti": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.1",
    "@swc/core": "^1.6.1",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.6",
    "barrelize": "^1.7.2",
    "eslint": "^10.3.0",
    "tsx": "^4.20.3",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  }
}